# Porta del server (default: 3001)
PORT=3001

# ─────────────────────────────────────────────
# PRODUZIONE — imposta queste variabili!
# ─────────────────────────────────────────────

# Chiave API Groq (ottieni gratis su console.groq.com)
# NON hardcodare la chiave nel codice, usa solo questa env var
GROQ_API_KEY=gsk_your_key_here

# Chiave segreta per JWT (cambiala in produzione!)
# Generane una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-string

# ─────────────────────────────────────────────
# DEPLOY — configurazioni per hosting
# ─────────────────────────────────────────────

# Su Railway: la variabile RAILWAY_PUBLIC_DOMAIN viene impostata automaticamente
# Su Render: usa RENDER_EXTERNAL_URL
# Su VPS: imposta manualmente
PUBLIC_URL=

# Stripe (per subscription - lascia vuoto se non usi pagamenti)
# Ottieni le chiavi su https://dashboard.stripe.com/apikeys
# pk_live_... (pubblica) e sk_live_... (segreta)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL dell'app Android (per CORS)
# In produzione, imposta il dominio del tuo backend qui
# Esempio: https://grow-api.onrender.com
APP_ORIGIN=*

# Versione corrente dell'app (per OTA update)
APP_VERSION=1.0.0
APP_BUILD=1
APP_UPDATE_URL=
APP_UPDATE_NOTES="Primo rilascio GROW"
